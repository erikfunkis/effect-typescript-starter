{
  "name": "typescript-effect-template",
  "version": "0.1.0",
  "private": true,
  "description": "Vite+ fullstack TypeScript starter centered on Effect v4 beta",
  "license": "ISC",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@effect/language-service": "0.85.1",
    "effect": "4.0.0-beta.66",
    "typescript": "5.9.3"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "vp run --recursive dev",
